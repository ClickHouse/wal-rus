# bench config, copy to config.env

# --- S3 target ---------------------------------------------------------------
BUCKET=my-wal-bench-bucket
AWS_REGION=us-east-1

# Static AWS keys for off-EC2; delete on EC2 to use IMDS
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
# Temporary/STS only
#AWS_SESSION_TOKEN=

# --- Postgres bench role -----------------------------------------------------
PGUSER=walbench
PGPASSWORD=change-me

# --- daemon / archiver tuning ------------------------------------------------
UPLOAD_CONCURRENCY=4          # wal-g WALG_UPLOAD_CONCURRENCY / pgbackrest process-max
WALG_COMPRESSION_METHOD=lz4

# --- workload sizing ---------------------------------------------------------
SCALE=5000                     # pgbench scale (~15 MB/unit; 5000 ≈ 75 GB)
CHURN_ROWS=2000000             # burst-phase churn table rows (must match pgbench_init)
BURST_SECONDS=300              # high-WAL burst phase (the heavy-load measurement)
#BURST_WORKERS=                # defaults to driver nproc

# --- operation benchmarks (run_op.sh / op_matrix.sh) -------------------------
# Point transient dirs at fast disk
#RESTORE_DIR=/dat/restore       # backup-fetch restores here
#WAL_RECV_DIR=/dat/walrecv      # wal-receive assembles segments here
# Sampler runs as postgres; keep results off a 0750 $HOME it can't traverse
#RESULTS_ROOT=/dat/bench-results # per-cell sampler CSVs + op_metrics land here
WAL_RECEIVE_SECONDS=300         # wal-receive streaming window (burst drives WAL)
# Delta churn window + chain depth
DELTA_CHURN_SECONDS=300
DELTA_MAX_STEPS=7
DELTA_ORIGIN=LATEST_FULL

# --- host conventions (override only if your box differs) --------------------
# BUILD_USER owns rust/cargo toolchain
#BUILD_USER=ubuntu
# Build walrus from a shipped source tarball instead of an in-repo checkout
# (fresh SUT with no .git). Make it on the dev box with
# bench/scripts/make_source_tarball.sh, scp it over, point this at it.
#WALRUS_SRC_TARBALL=/tmp/walrus-src.tar.gz
#WALRUS_SRC_DIR=/opt/walbench/src   # where the tarball is unpacked
# CIDR allowed in pg_hba
#DRIVER_CIDR=127.0.0.1/32
